{
  "expo": {
    "name": "CallTrack",
    "slug": "calltrack-mobile",
    "version": "1.0.0",
    "sdkVersion": "52.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "icon": "./assets/logo.png",
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "android": {
      "package": "com.calltrack.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "READ_CALL_LOG",
        "READ_CONTACTS"
      ]
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.calltrack.app"
    },
    "plugins": [
      "./app.plugin.js"
    ],
    "extra": {
      "apiUrl": "https://callby.vercel.app",
      "eas": {
        "projectId": "a93d0d8d-f7fd-410d-9524-106eed59ac9f"
      }
    },
    "owner": "ryanclinic"
  }
}
